{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd _bmad-output/backend && npm ci"
  },
  "deploy": {
    "startCommand": "node _bmad-output/backend/index.js",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
